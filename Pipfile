[[source]]
url = "https://pypi.org/simple"
verify_ssl = true
name = "pypi"

[packages]
fastapi = "*"
uvicorn = "*"
pydantic-settings = "*"
psycopg2-binary = "*"
alembic = "*"
sqlalchemy = "*"
pydantic = {extras = ["email"], version = "*"}

[dev-packages]

[requires]
python_version = "3.13"
python_full_version = "3.13.7"

[scripts]
start = "uvicorn app.main:app --reload"
upgrade = "alembic upgrade head"
autogenerate = "alembic revision --autogenerate -m"
init = "alembic init migration"
